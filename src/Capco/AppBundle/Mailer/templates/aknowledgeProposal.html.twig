{% extends "@CapcoMail/standardLayoutNew.html.twig" %}

{% set logo = app_logo_url() %}

{% set btnBg = capco_site_color_value('color.btn.bg') %}
{% if null == btnBg %}{% set btnBg = '#1ABC9C' %}{% endif %}
{% set btnText = capco_site_color_value('color.btn.text') %}
{% if null == btnText %}{% set btnText = '#FFF' %}{% endif %}
{% set linkText = capco_site_color_value('color.link.default') %}
{% if null == linkText %}{% set linkText = '#16a085' %}{% endif %}

{% if typeOfMail == 'create' %}
    {% set proposalDate =  sendAt|localizeddate('long', 'none', user_locale, timezone)  %}
    {% set proposalHour =  sendAt|date('H', timezone) ~ 'h' ~ sendAt|date('i', timezone) %}
{% endif %}

{% block core_mail %}
    <div>
        {% if logo is not null %}
            <img style="margin-bottom: 10px;" src="{{ logo }}" alt="logo {{ organizationName }}" />
        {% else %}
            <img style="margin-bottom: 10px;" src="{{ baseUrl ~ asset('apple-icon-76x76.png') }}" alt="" />
        {% endif %}

        <div style="color: #919191; font-size: 11px;">
            {% if typeOfMail == 'create' %}
                {{ proposalDate|upper }}
            {% else %}
                {{ proposalPublishedDate|upper }}
            {% endif %}
        </div>

        <h1 style="font-size: 18px; margin: 0 0 8px 0; color: #2B2B2B;">
            {{ 'notification.proposal.edit.participation.title'|trans({}, 'CapcoAppBundle', user_locale) | raw }}
        </h1>

        <div style="margin: 20px 0; text-align: left;">
            {% if typeOfMail == 'create' %}

                {% if not proposalPublished and confirmationUrl is not null %}
                    <div style="margin-top: 20px; color: #545E68;">
                        {{ 'unpublished-contribution-help-text'|trans({}, 'CapcoAppBundle', user_locale)|raw }}
                        <p>
                            <a href="" style="display: inline-block;color:{{ btnText }};padding:18px 24px;border-radius:4px;background-color: {{ btnBg }};font-weight: 600;">
                                {{ 'user.register.confirmation_message.validate'|trans({}, 'CapcoAppBundle', user_locale) }}
                            </a>
                        </p>
                    </div>
                {% endif %}

                <p style="margin: 24px 0 0 0; font-weight: 400; line-height: 24px; color: #5E5E5E; font-size: 14px;">
                    {{ 'participation_proposal_edit_email'|trans({
                        '{projectTitle}': projectTitle,
                        '{proposalTitle}': proposalTitle,
                        '{proposalPublishedDate}': proposalDate,
                        '{proposalPublishedDateTime}': proposalHour,
                        '{proposalShowUrl}': proposalShowUrl
                    }, 'CapcoAppBundle', user_locale)|raw }}
                </p>

                <div style="color: #545E68; text-align: left;">
                    <p style="margin: 0; line-height: 24px;">
                        {% if proposal.step.preventProposalEdit %}
                        {% else %}
                            {% if isTimeless %}
                                {{ 'you-can-still-edit-your-contribution'|trans(
                                    {},
                                    'CapcoAppBundle',
                                    user_locale
                                )|raw }}
                            {% else %}
                                {{ 'you-can-modify-it-until-the-step-is-closed'|trans(
                                    {},
                                    'CapcoAppBundle',
                                    user_locale
                                ) }}
                            {% endif %}
                        {% endif %}
                    </p>
                </div>

                <p style="margin: 0;">
                    <a href="{{ proposalEditUrl }}" style="color: {{ linkText }};">
                        {{ proposalEditUrl | u.truncate(75, '...') }}
                    </a>
                </p>
            {% else %}
                <p style="margin: 0 0 24px 0; font-weight: 400; line-height: 24px; color: #5E5E5E; font-size: 14px;">
                    {{ 'participation_proposal_edit_email'|trans({
                        '{projectTitle}': projectTitle,
                        '{proposalTitle}': proposalTitle,
                        '{proposalPublishedDate}': proposalPublishedDate,
                        '{proposalPublishedDateTime}': proposalPublishedDateTime,
                        '{proposalShowUrl}': proposalShowUrl
                    }, 'CapcoAppBundle', user_locale)|raw }}
                </p>

                <p style="margin: 0;">
                    <a href="{{ proposalEditUrl }}" style="color: {{ linkText }};">
                        {{ proposalEditUrl | u.truncate(75, '...') }}
                    </a>
                </p>
            {% endif %}
        </div>

    </div>
{% endblock %}

{% block footer_mail %}
    <div>
        <p style="margin: 0; text-align: left">
            {{ 'this-message-was-sent-because-you-participated-in-the-platform'|trans({'{platformName}': platformName}, 'CapcoAppBundle', user_locale) | raw }}
        </p>

        <p style="text-align: left;">
            {{ 'email.propulsed.by'|trans({}, 'CapcoAppBundle', user_locale) | raw }}
            <img src="{{ baseUrl ~ asset("capco-logo-mail.png")}}" alt="logo cap collectif" style="width: 15px;height: 15px;margin: 0 2px 0 4px;"  />
            {{ platformName }}
        </p>
    </div>
{% endblock %}
